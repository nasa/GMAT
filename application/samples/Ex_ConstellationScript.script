Create Spacecraft Sat11;

Sat11.DateFormat                   = TAIModJulian;
Sat11.Epoch                        = '21545';
Sat11.CoordinateSystem             = EarthMJ2000Eq;
Sat11.DisplayStateType             = Cartesian;
Sat11.X                            = 688.5272682812904;
Sat11.Y                            = -688.5272682812873;
Sat11.Z                            = 6928.410542950397;
Sat11.VX                           = -5.338534050664235;
Sat11.VY                           = -5.338534050664234;
Sat11.VZ                           = 2.287982201885771e-015;
Sat11.DryMass                      = 850;
Sat11.Cd                           = 2.2;
Sat11.Cr                           = 1.8;
Sat11.DragArea                     = 15;
Sat11.SRPArea                      = 1;
Sat11.NAIFId                       = -123456789;
Sat11.NAIFIdReferenceFrame         = -123456789;
Sat11.OrbitColor                   = Red;
Sat11.TargetColor                  = Teal;
Sat11.Id                           = 'SatId';
Sat11.Attitude                     = CoordinateSystemFixed;
Sat11.SPADSRPScaleFactor           = 1;
Sat11.ModelFile                    = '../data/vehicle/models/aura.3ds';
Sat11.ModelOffsetX                 = 0;
Sat11.ModelOffsetY                 = 0;
Sat11.ModelOffsetZ                 = 0;
Sat11.ModelRotationX               = 0;
Sat11.ModelRotationY               = 0;
Sat11.ModelRotationZ               = 0;
Sat11.ModelScale                   = 1.2;
Sat11.AttitudeDisplayStateType     = 'Quaternion';
Sat11.AttitudeRateDisplayStateType = 'AngularVelocity';
Sat11.AttitudeCoordinateSystem     = EarthMJ2000Eq;
Sat11.EulerAngleSequence           = '321';

