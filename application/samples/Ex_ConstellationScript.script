Sat44.ModelOffsetY                 = 0;
Sat44.ModelOffsetZ                 = 0;
Sat44.ModelRotationX               = 0;
Sat44.ModelRotationY               = 0;
Sat44.ModelRotationZ               = 0;
Sat44.ModelScale                   = 1.2;
Sat44.AttitudeDisplayStateType     = 'Quaternion';
Sat44.AttitudeRateDisplayStateType = 'AngularVelocity';
Sat44.AttitudeCoordinateSystem     = EarthMJ2000Eq;
Sat44.EulerAngleSequence           = '321';

%----------------------------------------
%---------- Formation
%----------------------------------------

Create Formation form;
form.Add = {Sat11, Sat12, Sat13, Sat14, Sat21, Sat22, Sat23, Sat24, Sat31, Sat32, Sat33, Sat34, Sat41, Sat42, Sat43, Sat44};


%----------------------------------------
%---------- ForceModels
%----------------------------------------

Create ForceModel fm;

fm.CentralBody  = Earth;
fm.PointMasses  = {Earth, Sun, Luna};
fm.Drag         = None;
fm.SRP          = Off;
fm.RelativisticCorrection = Off;
fm.ErrorControl = RSSStep;

%----------------------------------------
%---------- Propagators
%----------------------------------------

Create Propagator prop;

prop.FM              = fm;
prop.Type            = RungeKutta89;
prop.InitialStepSize = 60;
prop.Accuracy        = 9.999999999999999e-012;
prop.MinStep         = 0.001;
prop.MaxStep         = 2700;
prop.MaxStepAttempts = 50;
prop.StopIfAccuracyIsViolated = true;

%----------------------------------------
%---------- Subscribers
%----------------------------------------

Create OpenFramesInterface OFI_a3Dplot;

OFI_a3Dplot.SolverIterations     = Current;
OFI_a3Dplot.UpperLeft            = [ 0.1594117647058824 0.07029177718832891 ];
OFI_a3Dplot.Size                 = [ 0.6105882352941177 0.8474801061007957 ];
OFI_a3Dplot.RelativeZOrder       = 135;
OFI_a3Dplot.Maximized            = false;

OFI_a3Dplot.Add                  = {Sat11, Earth, Sat21, Sat31, Sat41, Sat12, Sat22, Sat32, Sat42, Sat13, Sat23, Sat33, Sat43, Sat14, Sat24, Sat34, Sat44};
OFI_a3Dplot.View                 = {a3Dplot_View, Earth_View};

OFI_a3Dplot.CoordinateSystem     = EarthMJ2000Eq;
OFI_a3Dplot.DrawObject           = [ true true true true true true true true true true true true true true true true true ];
OFI_a3Dplot.DrawXYPlane          = [ false false false false false false false false false false false false false false false false false];
OFI_a3Dplot.DrawLabel            = [ true true true true true true true true true true true true true true true true true ];
OFI_a3Dplot.DrawGrid             = [ false false false false false false false false false false false false false false false false false];

OFI_a3Dplot.Axes                 = On;
OFI_a3Dplot.XYPlane              = On;
OFI_a3Dplot.EclipticPlane        = Off;
OFI_a3Dplot.EnableStars          = On;
OFI_a3Dplot.StarCount            = 40000;
OFI_a3Dplot.ShowPlot             = true;

Create OpenFramesView a3Dplot_View;

a3Dplot_View.ViewFrame          = CoordinateSystem;
a3Dplot_View.SetDefaultLocation = On;
a3Dplot_View.SetCurrentLocation = Off;

a3Dplot_View.DefaultEye         = [ 30000 -20000 0 ]; 
a3Dplot_View.DefaultCenter      = [ 0 0 0 ];
a3Dplot_View.DefaultUp          = [ 0 0 1 ];

Create OpenFramesView Earth_View;

Earth_View.ViewFrame            = Earth;
Earth_View.ViewTrajectory       = Off;
Earth_View.InertialFrame        = Off;
Earth_View.SetDefaultLocation   = Off;
Earth_View.SetCurrentLocation   = On;
Earth_View.CurrentEye           = [ 4000 -20000 3000 ];
Earth_View.CurrentCenter        = [ 0 0 0 ];
Earth_View.CurrentUp            = [ 0 0 1 ];


%----------------------------------------
%---------- Mission Sequence
%----------------------------------------
BeginMissionSequence;

Propagate 'Prop 1 Day' prop(form) {Sat11.ElapsedSecs = 86400.0};



