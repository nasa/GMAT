LCROSSInit.DateFormat                   = TAIModJulian;
LCROSSInit.Epoch                        = '21545';
LCROSSInit.CoordinateSystem             = EarthMJ2000Eq;
LCROSSInit.DisplayStateType             = Cartesian;
LCROSSInit.X                            = 7100;
LCROSSInit.Y                            = 0;
LCROSSInit.Z                            = 1300;
LCROSSInit.VX                           = 0;
