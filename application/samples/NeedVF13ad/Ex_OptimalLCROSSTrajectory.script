%
%  Ex_OptimalLCROSSTrajectory
%
%  Demonstrates the use of an optimizer to target impact at a specific location 
%  on the lunar south pole, as was used for the LCROSS mission.
%



%----------------------------------------
%---------- Spacecraft
%----------------------------------------

Create Spacecraft LRO;

LRO.DateFormat = UTCGregorian;
LRO.Epoch                        = '01 Jan 2000 11:59:28.000';
LRO.CoordinateSystem             = EarthMJ2000Eq;
LRO.DisplayStateType             = Cartesian;
LRO.X                            = 7100;
LRO.Y                            = 0;
LRO.Z                            = 1300;
LRO.VX                           = 0;
LRO.VY                           = 7.35;
LRO.VZ                           = 1;
LRO.DryMass                      = 850;
LRO.Cd                           = 2.2;
LRO.Cr                           = 1.8;
LRO.DragArea                     = 15;
LRO.SRPArea                      = 1;
LRO.NAIFId                       = -123456789;
LRO.NAIFIdReferenceFrame         = -123456789;
LRO.Id                           = 'SatId';
LRO.Attitude                     = CoordinateSystemFixed;
LRO.ModelFile                    = '../data/vehicle/models/aura.3ds';
LRO.ModelOffsetX                 = 0;
LRO.ModelOffsetY                 = 0;
LRO.ModelOffsetZ                 = 0;
LRO.ModelRotationX               = 0;
LRO.ModelRotationY               = 0;
LRO.ModelRotationZ               = 0;
LRO.ModelScale                   = 3;
LRO.AttitudeDisplayStateType     = 'Quaternion';
LRO.AttitudeRateDisplayStateType = 'AngularVelocity';
LRO.AttitudeCoordinateSystem     = 'EarthMJ2000Eq';


